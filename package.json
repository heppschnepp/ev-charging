{
  "name": "ev-charging",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "EV Charging Station Finder",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter ev-server dev\" \"pnpm --filter ev-client dev\"",
    "build": "pnpm --parallel --filter \"*\" build",
    "lint": "pnpm --parallel --filter \"*\" lint",
    "type-check": "pnpm --parallel --filter \"*\" type-check",
    "clean": "pnpm --recursive clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "client:dev": "pnpm --filter ev-client dev",
    "client:build": "pnpm --filter ev-client build",
    "server:dev": "pnpm --filter ev-server dev",
    "server:build": "pnpm --filter ev-server build",
    "server:start": "pnpm --filter ev-server start"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.19",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "typescript": "~5.5.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "client",
    "server"
  ]
}
